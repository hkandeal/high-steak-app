# Copy to .env.local (gitignored) for SendGrid in Docker Compose.
# Mail is disabled without this file (see application.yml defaults).

MAIL_ENABLED=true
MAIL_FROM=High Steaks <noreply@notify.hossam.io>
APP_BASE_URL=http://localhost:5173

SPRING_MAIL_HOST=smtp.sendgrid.net
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=apikey
SPRING_MAIL_PASSWORD=SG.replace-with-your-sendgrid-api-key
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true
